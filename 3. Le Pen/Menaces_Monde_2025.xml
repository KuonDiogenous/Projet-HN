                    <persName xml:id="Jordan_Bardella"/>
                </item>
                <item>
                    <persName xml:id="Rémy_Heitz"/>
                </item>
                <item>
                    <orgName xml:id="RTL"/>
                </item>
                <item>
                    <orgName xml:id="Parquet_général"/>
                </item>
